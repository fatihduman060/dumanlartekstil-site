span class="ͼj">1302</span><span>, </span><span class="ͼm">cy</span><span class="ͼg">+</span><span class="ͼj">20</span><span class="ͼg">+</span><span class="ͼm">j</span><span class="ͼg">*</span><span class="ͼj">20</span><span>), </span><span class="ͼm">line</span><span>, </span><span class="ͼm">font</span><span class="ͼg">=</span><span class="ͼm">f_small_b</span><span>, </span><span class="ͼm">fill</span><span class="ͼg">=</span><span class="ͼm">white</span><span>)</span><br><span>    </span><span class="ͼm">draw</span><span class="ͼg">.</span><span>line((</span><span class="ͼj">1302</span><span>, </span><span class="ͼm">cy</span><span class="ͼg">+</span><span class="ͼj">58</span><span>, </span><span class="ͼj">1638</span><span>, </span><span class="ͼm">cy</span><span class="ͼg">+</span><span class="ͼj">58</span><span>), </span><span class="ͼm">fill</span><span class="ͼg">=</span><span>(</span><span class="ͼj">255</span><span>,</span><span class="ͼj">255</span><span>,</span><span class="ͼj">255</span><span>,</span><span class="ͼj">38</span><span>), </span><span class="ͼm">width</span><span class="ͼg">=</span><span class="ͼj">1</span><span>)</span><br><span>    </span><span class="ͼm">cy</span><span> </span><span class="ͼg">+=</span><span> </span><span class="ͼj">78</span><br><br><span class="ͼe"># Social icons</span><br><span class="ͼm">sx</span><span>, </span><span class="ͼm">sy</span><span> </span><span class="ͼg">=</span><span> </span><span class="ͼj">1240</span><span>, </span><span class="ͼj">482</span><br><span class="ͼg">for</span><span> </span><span class="ͼm">i</span><span>, </span><span class="ͼm">label</span><span> </span><span class="ͼg">in</span><span> </span><span class="ͼm">enumerate</span><span>([</span><span class="ͼk">"in"</span><span>, </span><span class="ͼk">"◎"</span><span>, </span><span class="ͼk">"▶"</span><span>]):</span><br><span>    </span><span class="ͼm">cx</span><span> </span><span class="ͼg">=</span><span> </span><span class="ͼm">sx</spa