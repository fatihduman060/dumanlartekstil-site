><span class="ͼg">=</span><span>(</span><span class="ͼj">4</span><span>,</span><span class="ͼj">17</span><span>,</span><span class="ͼj">31</span><span>), </span><span class="ͼm">outline</span><span class="ͼg">=</span><span class="ͼm">gold2</span><span>, </span><span class="ͼm">width</span><span class="ͼg">=</span><span class="ͼj">2</span><span>)</span><br><span class="ͼm">draw</span><span class="ͼg">.</span><span>text((</span><span class="ͼm">center_x</span><span class="ͼg">-</span><span class="ͼj">18</span><span>, </span><span class="ͼm">H</span><span class="ͼg">-</span><span class="ͼj">125</span><span>), </span><span class="ͼk">"D"</span><span>, </span><span class="ͼm">font</span><span class="ͼg">=</span><span class="ͼm">f_emblem</span><span>, </span><span class="ͼm">fill</span><span class="ͼg">=</span><span class="ͼm">gold</span><span>)</span><br><span class="ͼe"># legal bottom line</span><br><span class="ͼm">draw</span><span class="ͼg">.</span><span>text((</span><span class="ͼj">130</span><span>, </span><span class="ͼm">H</span><span class="ͼg">-</span><span class="ͼj">56</span><span>), </span><span class="ͼk">"© 2026 Dumanlar A.Ş. Tüm hakları saklıdır."</span><span>, </span><span class="ͼm">font</span><span class="ͼg">=</span><span class="ͼm">f_tiny</span><span>, </span><span class="ͼm">fill</span><span class="ͼg">=</span><span class="ͼm">soft</span><span>)</span><br><span class="ͼm">legal</span><span> </span><span class="ͼg">=</span><span> </span><span class="ͼk">"KVKK Aydınlatma Metni     |     Gizlilik Politikası     |     Çerez Politikası"</span><br><span class="ͼm">bbox</span><span> </span><span class="ͼg">=</span><span> </span><span class="ͼm">draw</span><span class="ͼg">.</span><span>textbbox((</span><span class="ͼj">0</span><span>,</span><span class="ͼj">0</span><span>), </span><span class="ͼm">legal</span><span>, </span><span class="ͼm">font</span><span class="ͼg">=</span><span class="ͼm">f_tiny</span><span>)</span><br><span class="ͼm">draw</span><span