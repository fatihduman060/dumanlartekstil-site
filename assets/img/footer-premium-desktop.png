<li data-section-id="1cigr3l" data-start="354" data-end="385">
<p data-start="356" data-end="385"><strong data-start="356" data-end="385">desktop footer background</strong></p>
</li>
<li data-section-id="bhb0h5" data-start="386" data-end="430">
<p data-start="388" data-end="430">yani footer’ın dekoratif arka planı olacak</p>
</li>
<li data-section-id="3amczt" data-start="431" data-end="550">
<p data-start="433" data-end="450">üstüne biz kodla:</p>
<ul data-start="453" data-end="550">
<li data-section-id="1qf1rmj" data-start="453" data-end="463">
<p data-start="455" data-end="463">Sayfalar</p>
</li>
<li data-section-id="235sfz" data-start="466" data-end="483">
