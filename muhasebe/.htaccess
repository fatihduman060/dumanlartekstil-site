Options -Indexes

<FilesMatch "^(config|bootstrap|layout|auth)\.php$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Deny from all
  </IfModule>
</FilesMatch>

<FilesMatch "\.(sqlite|db|bak|log)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Deny from all
  </IfModule>
</FilesMatch>

<IfModule mod_substitute.c>
  AddOutputFilterByType SUBSTITUTE text/html
  Substitute "s#assets/muhasebe.js?v=516"></script>#assets/muhasebe.js?v=516"></script><script src=\"assets/super-admin-role.js?v=1\"></script>#ni"
</IfModule>
