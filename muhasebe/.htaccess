Options -Indexes

<FilesMatch "^(config|bootstrap|layout|auth)\.php$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Deny from all
  </IfModule>
</FilesMatch>

<FilesMatch "\.(sqlite|db|bak|log)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Deny from all
  </IfModule>
</FilesMatch>

<IfModule mod_substitute.c>
  AddOutputFilterByType SUBSTITUTE text/html
  Substitute "s|+90 356 715 82 83|0 (356) 715 82 83|ni"
  Substitute "s|0(356)715 82 83|0 (356) 715 82 83|ni"
  Substitute "s|height:286mm!important|height:297mm!important|ni"
  Substitute "s|width:209mm!important|width:210mm!important|ni"
  Substitute "s|</head>|<style>@page{size:A4;margin:0!important}.title-wrap h1{font-size:7.2mm!important;line-height:1.02!important;letter-spacing:.15mm!important;font-weight:800!important;max-width:72mm!important}.title-rule{width:44mm!important;margin:2mm 0 3mm!important}.customer-name{font-size:7.8mm!important;line-height:1.12!important;font-weight:950!important;color:#061a33!important;letter-spacing:.08mm!important;margin-bottom:4mm!important;max-width:132mm!important}.city{font-size:5mm!important;font-weight:950!important}.doc-head{margin-bottom:5mm!important}@media print{html,body{margin:0!important;padding:0!important;width:210mm!important;height:297mm!important}.page{width:210mm!important;height:297mm!important;margin:0!important;box-shadow:none!important;border:0!important}.title-wrap h1{font-size:6.8mm!important}.customer-name{font-size:7.2mm!important}}</style><link rel=\"stylesheet\" href=\"assets/muhasebe-polish.css?v=6\" /></head>|ni"
  Substitute "s|</body>|<script src=\"assets/super-admin-role.js?v=1\"></script><script src=\"assets/muhasebe-polish.js?v=3\"></script><script src=\"assets/cek-vade-uyari.js?v=1\"></script></body>|ni"
</IfModule>
