Options -Indexes

<FilesMatch "^(config|bootstrap|layout|auth)\.php$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Deny from all
  </IfModule>
</FilesMatch>

<FilesMatch "\.(sqlite|db|bak|log)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Deny from all
  </IfModule>
</FilesMatch>

<IfModule mod_substitute.c>
  AddOutputFilterByType SUBSTITUTE text/html
  Substitute "s|</head>|<link rel=\"stylesheet\" href=\"assets/muhasebe-polish.css?v=1\" /></head>|ni"
  Substitute "s|</body>|<script src=\"assets/super-admin-role.js?v=1\"></script><script src=\"assets/muhasebe-polish.js?v=1\"></script><script src=\"assets/cek-vade-uyari.js?v=1\"></script></body>|ni"
</IfModule>
